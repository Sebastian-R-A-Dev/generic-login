# ArcadeCore API origin (no trailing slash). Login: POST {origin}/api/v1/auth/login
NEXT_PUBLIC_ARCADECORE_API_BASE_URL=http://localhost:4000

# Support inbox for questions (mailto link on the login card)
NEXT_PUBLIC_SUPPORT_EMAIL=support@example.com

# JSON map: app identifier shown on login (redirect-to). Post-login redirect comes from API (App.url).

NEXT_PUBLIC_REGISTERED_APPS_JSON={"ADMIN_APP":"http://localhost:3001","ENGLISH-CHALLENGE":"http://localhost:3002","QUIZ_APP":"http://localhost:3002"}

# App used on /login when ?redirect-to= is missing (player apps preferred over ADMIN_APP)
NEXT_PUBLIC_DEFAULT_LOGIN_APP=ENGLISH-CHALLENGE
